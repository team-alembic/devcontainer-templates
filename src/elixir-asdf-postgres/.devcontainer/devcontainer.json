{
  "name": "${templateOption:projectName}",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${templateOption:projectName}",
  "initializeCommand": "mkdir -p $HOME/.claude",
  "forwardPorts": [4000, "db:5432"],
  "portsAttributes": {
    "4000": {
      "label": "Phoenix Dev Server"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli": {},
    "ghcr.io/devcontainers-extra/features/apt-packages:1": {
      "packages": "autoconf,m4,libwxgtk3.2-dev,libwxgtk-webview3.2-dev,libgl1-mesa-dev,libglu1-mesa-dev,libpng-dev,libssh-dev,unixodbc-dev,xsltproc,fop,libxml2-utils,libncurses-dev"
    },
    "ghcr.io/devcontainer-community/devcontainer-features/asdf-vm.com:1": {}
  },
  "onCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "animus-coop.vscode-elixir-mix-formatter",
        "royalmist.vscode-eex-format",
        "jakebecker.elixir-ls",
        "iampeterbanjo.elixirlinter",
        "pgourlain.erlang",
        "szTheory.erlang-formatter"
      ]
    }
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "ANTHROPIC_AUTH_TOKEN": "${localEnv:ANTHROPIC_AUTH_TOKEN}",
    "DATABASE_HOST": "db",
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8"
  }
}
