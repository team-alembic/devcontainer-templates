{
  "name": "${templateOption:projectName}",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${templateOption:projectName}",
  "forwardPorts": [4000, "db:5432"],
  "portsAttributes": {
    "4000": {
      "label": "Phoenix Dev Server"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli": {},
    "ghcr.io/devcontainers-extra/features/apt-packages:1": {
      "packages": "autoconf,m4,libwxgtk3.2-dev,libwxgtk-webview3.2-dev,libgl1-mesa-dev,libglu1-mesa-dev,libpng-dev,libssh-dev,unixodbc-dev,xsltproc,fop,libxml2-utils,libncurses-dev"
    },
    "ghcr.io/devcontainer-community/devcontainer-features/asdf-vm.com:1": {}
  },
  "onCreateCommand": "bash .devcontainer/setup.sh",
  "remoteEnv": {
    "DATABASE_HOST": "db",
    "LANG": "C.UTF-8"
  }
}
